# Base image selection
# GPU example: pytorch/pytorch:2.2.2-cuda12.1-cudnn8-runtime
# CPU example: pytorch/pytorch:2.2.2-cpu
BASE_IMAGE=pytorch/pytorch:2.2.2-cuda12.1-cudnn8-runtime

# GPU control for Docker Compose (used with compose.gpu.yaml)
# 0 = CPU only, 1 = single GPU, all = all GPUs
NVIDIA_VISIBLE_DEVICES_COUNT=all

# Weights & Biases
WANDB_MODE=offline
WANDB_PROJECT=mot-thesis
WANDB_API_KEY=
WANDB_DIR=/workspace/wandb

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_PORT=5001

# Jupyter
JUPYTER_PORT=8888
JUPYTER_TOKEN=mot
